NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ALLOWED_EMAILS=you@example.com
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
CRON_SECRET=YOUR_LONG_RANDOM_SECRET
ASSISTANT_USER_EMAIL=you@example.com
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
# Needs calendar.readonly, gmail.readonly, drive.readonly, drive.file scopes.
# Mint one with: node scripts/google-oauth-setup.mjs
GOOGLE_REFRESH_TOKEN=YOUR_GOOGLE_REFRESH_TOKEN
# Comma-separate multiple calendars to sync more than just primary,
# e.g. "primary,school@group.calendar.google.com,work@group.calendar.google.com"
GOOGLE_CALENDAR_ID=primary
# How many days ahead to pull events (default 10 if unset).
GOOGLE_CALENDAR_LOOKAHEAD_DAYS=10
GOOGLE_GMAIL_QUERY=newer_than:2d (is:important OR label:starred OR category:primary)
GOOGLE_TIMEZONE=America/New_York
# Comma-separate multiple external .ics feed URLs (e.g. work schedule tools
# like StaffReady) to sync them straight from source instead of through a
# Google-subscribed copy, which can lag 12-24h. These URLs are bearer
# secrets (auth is embedded in the path) — treat like a password.
ICS_CALENDAR_URLS=https://example.com/calendar/feed.ics
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
OPENROUTER_MODEL=anthropic/claude-haiku-4.5
# Capture enrichment (video transcripts, articles) uses a separate, stronger
# model override since it needs more reasoning + a bigger context window than
# chat/brief. Defaults to Sonnet if unset.
OPENROUTER_ENRICHMENT_MODEL=anthropic/claude-sonnet-4.5
# Absolute path to your local Obsidian vault. Only set on machines with real
# filesystem access to it — leave unset in cloud deploys, exports fall back
# to returning markdown instead of writing files. Used by both the Obsidian
# export route and the capture enrichment pipeline.
OBSIDIAN_VAULT_PATH=/Users/you/path/to/your-vault
