<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.focusos.server</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-lc</string>
    <string>cd "/Users/matthewprasanth/focus-os" &amp;&amp; set -a &amp;&amp; source .env.local &amp;&amp; set +a &amp;&amp; port=$(echo "$NEXT_PUBLIC_APP_URL" | sed -E 's#.*:([0-9]+).*#\1#'); exec npx next dev --port "${port:-3000}"</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/Users/matthewprasanth/Library/Logs/focusos-server.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/matthewprasanth/Library/Logs/focusos-server.log</string>
</dict>
</plist>
